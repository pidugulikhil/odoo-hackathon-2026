# Environment Configuration for TransitOps Backend
# Copy this file to .env and fill in the values

# PostgreSQL Database URL
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:Odoo-Hackathon-2026@localhost:5432/transitops"

# JWT Configuration
JWT_SECRET="transitops-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS - Frontend origin
FRONTEND_URL="http://localhost:5173"
